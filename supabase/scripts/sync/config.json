{
  "_comment": "Sensitive values (projectRef, databaseUrl, dockerContainer) are loaded from .env.local",
  "version": "1.0.0",
  "production": {
    "projectRef": "${SUPABASE_PROD_PROJECT_REF}",
    "verifyBeforeSync": true
  },
  "local": {
    "databaseUrl": "${SUPABASE_LOCAL_DATABASE_URL}",
    "dockerContainer": "${SUPABASE_LOCAL_DOCKER_CONTAINER}"
  },
  "sync": {
    "includeTables": ["*"],
    "excludeTables": [],
    "includeAuthUsers": true,
    "includeStorage": false,
    "anonymize": false
  },
  "anonymization": {
    "enabled": false,
    "rules": []
  },
  "backup": {
    "enabled": "${SUPABASE_BACKUP_ENABLED}",
    "retentionDays": "${SUPABASE_BACKUP_RETENTION_DAYS}",
    "maxBackups": "${SUPABASE_BACKUP_MAX_BACKUPS}",
    "compression": "${SUPABASE_BACKUP_COMPRESSION}"
  },
  "output": {
    "directory": "supabase/scripts/sync/dumps",
    "compression": false
  }
}
