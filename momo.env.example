# MoMo Payment Integration Configuration
# Copy this file to .env.local and update with your actual values

# MoMo API Configuration (Client-side)
VITE_MOMO_API_URL=https://momosv3.apimienphi.com
VITE_MOMO_ACCESS_TOKEN=your_access_token_here
VITE_MOMO_RECEIVER_PHONE=0931275909

# MoMo Webhook Configuration (Server-side only - do not expose to client)
# This should be stored in environment variables on your server/Vercel/etc
MOMO_WEBHOOK_SIGNATURE=your_webhook_signature_here

# Supabase Service Role (Server-side only - for webhook processing)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
